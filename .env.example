# ── BizHunt Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local for local dev, then add the same vars in the
# Vercel dashboard under Project → Settings → Environment Variables.
# NEVER commit .env.local to git.

# Google Maps / Places API key
# Enable: Places API (New) at https://console.cloud.google.com/apis/library
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Anthropic Claude API key
# Get it at: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
